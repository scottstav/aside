# aside configuration
#
# Copy to: $XDG_CONFIG_HOME/aside/config.toml
#          (usually ~/.config/aside/config.toml)
#
# Only uncomment the values you want to change — aside uses sensible
# defaults for everything.

# ---------------------------------------------------------------------------
# Model
# ---------------------------------------------------------------------------
# Uses LiteLLM format: provider/model-name
# Examples: anthropic/claude-sonnet-4-6, openai/gpt-4o, ollama/llama3
[model]
# name = "anthropic/claude-sonnet-4-6"
# system_prompt = ""

# ---------------------------------------------------------------------------
# Input
# ---------------------------------------------------------------------------
[input]
# terminal = "foot -e"
# font = ""

# ---------------------------------------------------------------------------
# Voice (speech-to-text)
# ---------------------------------------------------------------------------
[voice]
# enabled = false
# stt_model = "base"
# stt_device = "cpu"
# smart_silence = true
# silence_timeout = 2.5
# no_speech_timeout = 3.0
# force_send_phrases = ["send it", "that's it"]

# ---------------------------------------------------------------------------
# Text-to-Speech
# ---------------------------------------------------------------------------
[tts]
# enabled = false
# model = ""
# speed = 1.0

[tts.filter]
# skip_code_blocks = true
# skip_urls = true

# ---------------------------------------------------------------------------
# Overlay
# ---------------------------------------------------------------------------
[overlay]
# font = "Sans 13"
# width = 600
# max_lines = 5
# position = "top-center"
# margin_top = 10
# margin_right = 0
# margin_bottom = 0
# margin_left = 0
# padding_x = 20
# padding_y = 16
# corner_radius = 12
# border_width = 2
# accent_height = 3
# scroll_duration = 200
# fade_duration = 400

[overlay.colors]
# background = "#1a1b26e6"
# foreground = "#c0caf5ff"
# border = "#414868ff"
# accent = "#7aa2f7ff"
# user_accent = "#a07048ff"

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
[storage]
# conversations_dir = ""             # JSON conversation state files
# archive_dir = ""                   # exported markdown transcripts

# ---------------------------------------------------------------------------
# Tools
# ---------------------------------------------------------------------------
[tools]
# dirs = []

# ---------------------------------------------------------------------------
# Status bar
# ---------------------------------------------------------------------------
[status]
# signal = 12                        # SIGRTMIN+N sent to waybar on state changes
