# aside configuration
#
# Copy to: $XDG_CONFIG_HOME/aside/config.toml
#          (usually ~/.config/aside/config.toml)
#
# Only uncomment the values you want to change — aside uses sensible
# defaults for everything.

# ---------------------------------------------------------------------------
# Model
# ---------------------------------------------------------------------------
# Uses LiteLLM format: provider/model-name
# Examples: anthropic/claude-sonnet-4-6, openai/gpt-4o, ollama/llama3
[model]
# name = "anthropic/claude-sonnet-4-6"
# system_prompt = ""

# ---------------------------------------------------------------------------
# Input
# ---------------------------------------------------------------------------
[input]
# Terminal emulator used to launch the input window.
# Must accept -e to run a command (foot, alacritty, kitty, etc.)
# terminal = "foot -e"

# ---------------------------------------------------------------------------
# Voice
# ---------------------------------------------------------------------------
[voice]
# enabled = false
# stt_model = "base"             # faster-whisper model size
# stt_device = "cpu"             # "cpu" or "cuda"
# smart_silence = true           # end recording on silence detection
# silence_timeout = 2.5          # seconds of silence before auto-send
# no_speech_timeout = 3.0        # seconds with no speech before cancelling
# force_send_phrases = ["send it", "that's it"]

# ---------------------------------------------------------------------------
# Text-to-Speech
# ---------------------------------------------------------------------------
[tts]
# enabled = false
# model = "af_heart"             # kokoro voice model
# speed = 1.0
# lang = "a"                     # kokoro language code

[tts.filter]
# skip_code_blocks = true        # don't read code blocks aloud
# skip_urls = true               # don't read URLs aloud

# ---------------------------------------------------------------------------
# Overlay
# ---------------------------------------------------------------------------
[overlay]
# font = "Sans 13"
# width = 600                    # 200–2000 logical pixels
# max_lines = 40                 # 1–50 lines of visible text
# position = "top-center"        # top-left, top-center, top-right,
#                                # bottom-left, bottom-center, bottom-right, center
# margin_top = 10
# margin_right = 0
# margin_bottom = 0
# margin_left = 0
# padding_x = 20
# padding_y = 16
# corner_radius = 12
# border_width = 2
# accent_height = 3
# scroll_duration = 200          # ms
# fade_duration = 400            # ms

[overlay.colors]
# background = "#1a1b26e6"       # RGBA hex (last two digits = alpha)
# foreground = "#c0caf5ff"
# border = "#414868ff"
# accent = "#7aa2f7ff"

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
[storage]
# conversations_dir = ""         # default: $XDG_STATE_HOME/aside/conversations
# archive_dir = ""               # default: $XDG_STATE_HOME/aside/archive

# ---------------------------------------------------------------------------
# Plugins
# ---------------------------------------------------------------------------
[plugins]
# dirs = []                      # additional plugin directories to scan

# ---------------------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------------------
[notifications]
# reply_command = ""             # command to run when a reply arrives
# listen_command = ""            # command to run when listening starts

# ---------------------------------------------------------------------------
# Status
# ---------------------------------------------------------------------------
[status]
# signal = 12                    # SIGRTMIN+N signal for waybar updates
